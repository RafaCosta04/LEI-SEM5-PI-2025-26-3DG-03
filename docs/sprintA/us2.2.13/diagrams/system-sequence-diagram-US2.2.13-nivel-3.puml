@startuml Qualifications
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Person(LOA, "Logistics Operator", "System user managing logistics operations")

Container_Boundary(Qualificationapi, "Qualification API") {
    Component(QualificationController, "Qualification Controller", "ASP.NET Core MVC Controller", "Handles HTTP requests related to qualifications")
    Component(QualificationService, "Qualification Service", ".NET 8 (ASP.NET Core)", "Business logic for qualifications")
    Component(Qualification, "Qualification", "Domain Model", "Represents a qualification")
    Component(QualificationRepository, "Qualification Repository", ".NET 8 (ASP.NET Core)", "Data access for qualifications")
    Component(DbContext, "DbContext", ".NET 8 (Entity Framework Core)", "EF Core DbContext for Shipping Management")
    ContainerDb(db, "Shipping Management Database", "SQL Server", "Stores all data related to shipping management")
}

QualificationService -[hidden]right-> Qualification
QualificationRepository -[hidden]right-> DbContext


Rel(LOA, QualificationController, "Sends HTTP requests", "HTTPS/JSON")
Rel(QualificationController, QualificationService, "Calls methods in", "Method Calls")
Rel(QualificationService, Qualification, "Uses", "Domain Logic")
Rel(QualificationService, QualificationRepository, "Uses", "Method Calls")
Rel(QualificationRepository, DbContext, "Uses", "Method Calls")
Rel(DbContext, db, "Reads from and writes to", "EF Core/SQL")

@enduml