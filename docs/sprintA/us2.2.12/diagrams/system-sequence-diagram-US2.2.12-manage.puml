@startuml 2.2.12

skinparam Monochrome true
skinparam PackageStyle rectangle
skinparam shadowing false

actor "Logistics Operator" as LO 
participant "System" as SYS

title System Sequence Diagram - US2.2.12

== Manage Physical Resources ==
activate LO


LO -> SYS : Asks to Manage the Physical Resource\n(fixed cranes, mobile cranes and trucks)
activate SYS
SYS -> LO : Request which Physical Resource he wants to Manage
deactivate SYS
LO -> SYS : Selects the Physical Resouce he wants to Manage
activate SYS
SYS -> LO : Requests what Operation wants to do\n(update, deactivate)
deactivate SYS
LO -> SYS : Inserts the wanted Operation
activate SYS
SYS -> LO : Confirms Physical Resource Operation 
deactivate SYS
deactivate LO
@enduml