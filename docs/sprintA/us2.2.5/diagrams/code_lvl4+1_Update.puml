@startuml code_lvl4+1_Update_ShippingAgentOrganization
!define RECTANGLE class

title Sequence Diagram - PUT ShippingAgentOrganization Update (Level 4+1)

actor Client
participant "ShippingAgentOrganizationController" as Controller
participant "ShippingAgentOrganizationService" as Service
participant "IShippingAgentOrganizationRepository" as SARepository
participant "ShippingAgentOrganizationMapper" as SAMapper
participant "ShippingAgentOrganization" as SADomain
participant "ShippingAgentOrganizationDataModel" as SADataModel
database "ShippingManagementContext" as Database

Client -> Controller : PUT /api/ShippingAgentOrganization/Update/{id}\n(long id, ShippingAgentOrganizationDTO organizationDTO)

activate Controller
Controller -> Controller : Validate organizationDTO != null

Controller -> Service : UpdateShippingAgentOrganization(id, organizationDTO, errorMessages)
activate Service

' Check if organization exists by ID
Service -> SARepository : GetShippingAgentOrganizationByIdAsync(id)
activate SARepository
SARepository -> Database : SingleOrDefaultAsync(sa => sa.Id == id)
activate Database
Database --> SARepository : ShippingAgentOrganizationDataModel or null
deactivate Database

alt Organization not found
    SARepository --> Service : null
    deactivate SARepository
    Service -> Service : errorMessages.Add("Organization not found")
    Service --> Controller : false
else Organization found
    SARepository -> SAMapper : ToDomain(organizationDataModel)
    activate SAMapper
    SAMapper --> SARepository : ShippingAgentOrganization (existing)
    deactivate SAMapper
    SARepository --> Service : ShippingAgentOrganization (existing)
    deactivate SARepository
    
    Service -> Service : Validate organizationDTO fields\n(Code, LegalName, AlternativeName, Address, TaxNumber)
    
    opt Validation fails
        Service -> Service : errorMessages.Add(validation errors)
        Service --> Controller : false
    end
    
    Service -> Service : Normalize code = organizationDTO.Code.ToUpper().Trim()
    Service -> Service : Validate code regex "^[A-Z0-9]+$"
    
    opt Code format invalid
        Service -> Service : errorMessages.Add("Code must be alphanumeric")
        Service --> Controller : false
    end

    Service -> SARepository : GetShippingAgentOrganizationByLegalNameAsync(organizationDTO.LegalName)
    activate SARepository
    SARepository -> Database : SingleOrDefaultAsync(sa => sa.LegalName == legalName)
    activate Database
    Database --> SARepository : ShippingAgentOrganizationDataModel or null
    deactivate Database
    
    alt LegalName exists in different organization
        SARepository -> SAMapper : ToDomain(organizationDataModel)
        activate SAMapper
        SAMapper --> SARepository : ShippingAgentOrganization
        deactivate SAMapper
        SARepository --> Service : ShippingAgentOrganization (with different ID)
        deactivate SARepository
        
        Service -> Service : Check if organization.Id != id
        Service -> Service : errorMessages.Add("LegalName already exists")
        Service --> Controller : false
    else LegalName available or same organization
        SARepository --> Service : null or same organization
        deactivate SARepository

        Service -> SARepository : GetShippingAgentOrganizationByAddressAsync(organizationDTO.Address)
        activate SARepository
        SARepository -> Database : SingleOrDefaultAsync(sa => sa.Address == address)
        activate Database
        Database --> SARepository : ShippingAgentOrganizationDataModel or null
        deactivate Database
        
        alt Address exists in different organization
            SARepository --> Service : ShippingAgentOrganization (with different ID)
            deactivate SARepository
            Service -> Service : errorMessages.Add("Address already exists")
            Service --> Controller : false
        else Address available or same organization
            SARepository --> Service : null or same organization
            deactivate SARepository

            Service -> SARepository : GetShippingAgentOrganizationByTaxNumberAsync(organizationDTO.TaxNumber)
            activate SARepository
            SARepository -> Database : SingleOrDefaultAsync(sa => sa.TaxNumber == taxNumber)
            activate Database
            Database --> SARepository : ShippingAgentOrganizationDataModel or null
            deactivate Database
            
            alt TaxNumber exists in different organization
                SARepository --> Service : ShippingAgentOrganization (with different ID)
                deactivate SARepository
                Service -> Service : errorMessages.Add("TaxNumber already exists")
                Service --> Controller : false
            else TaxNumber available or same organization
                SARepository --> Service : null or same organization
                deactivate SARepository

                Service -> SARepository : GetShippingAgentOrganizationByCodeAsync(organizationDTO.Code)
                activate SARepository
                SARepository -> Database : SingleOrDefaultAsync(sa => sa.Code == code)
                activate Database
                Database --> SARepository : ShippingAgentOrganizationDataModel or null
                deactivate Database
                
                alt Code exists in different organization
                    SARepository --> Service : ShippingAgentOrganization (with different ID)
                    deactivate SARepository
                    Service -> Service : errorMessages.Add("Code already exists")
                    Service --> Controller : false
                else Code available or same organization
                    SARepository --> Service : null or same organization
                    deactivate SARepository

                    Service -> SARepository : Update(organization, errorMessages)
                    activate SARepository
                    SARepository -> Database : FirstOrDefaultAsync(v => v.Id == organization.Id)
                    activate Database
                    Database --> SARepository : ShippingAgentOrganizationDataModel
                    deactivate Database
                    
                    SARepository -> SAMapper : UpdateDataModelAsync(organizationDataModel, organization, context)
                    activate SAMapper
                    SAMapper -> SADataModel : Update properties\n(Code, LegalName, AlternativeName, Address, TaxNumber, LastModifiedAt)
                    activate SADataModel
                    SADataModel --> SAMapper : Updated ShippingAgentOrganizationDataModel
                    deactivate SADataModel
                    SAMapper --> SARepository : void
                    deactivate SAMapper
                    
                    SARepository -> Database : SaveChangesAsync()
                    activate Database
                    Database --> SARepository : Changes saved
                    deactivate Database
                    
                    SARepository -> SAMapper : ToDomain(organizationDataModel)
                    activate SAMapper
                    SAMapper --> SARepository : Updated ShippingAgentOrganization
                    deactivate SAMapper
                    SARepository --> Service : Updated ShippingAgentOrganization
                    deactivate SARepository
                    
                    Service --> Controller : true
                end
            end
        end
    end
end

deactivate Service

alt Update successful
    Controller --> Client : 200 OK
else Conflict (Name, Address, TaxNumber, or Code already exists)
    Controller --> Client : 409 Conflict\n(errorMessages)
else Bad Request (Validation errors)
    Controller --> Client : 400 Bad Request\n(errorMessages)
end

deactivate Controller

@enduml
