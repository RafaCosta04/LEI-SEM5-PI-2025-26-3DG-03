@startuml ShippingAgentOrganizationComponents

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml


Person(PAO, "Port Authority Officer", "System user managing port authority operations")

Container_Boundary(shippApi, "Shipping Agent Organization API") {
    Component(ShippingAgentOrganizationController, "Shipping Agent Organization Controller", "ASP.NET Core MVC Controller", "Handles HTTP requests related to Vessels")
    Component(ShippingAgentOrganizationService, "Shipping Agent Organization Service", ".NET 8 (ASP.NET Core)", "Business logic for Shipping Agent Organizations")
    Component(ShippingAgentOrganization, "Shipping Agent Organization", "Domain Model", "Represents a Shipping Agent Organization")
    Component(ShippingAgentOrganizationRepository, "Shipping Agent Organization Repository", ".NET 8 (ASP.NET Core)", "Data access for Shipping Agent Organizations")
    Component(DbContext, "DbContext", ".NET 8 (Entity Framework Core)", "EF Core DbContext for Shipping Management")
    ComponentDb(db, "Shipping Management Database", "SQL Server", "Stores all data related to shipping management")

    Component(RepresentativeService, "Representative Service", ".NET 8 (ASP.NET Core)", "Business logic for Representatives")
    Component(RepresentativeRepository, "Representative Repository", ".NET 8 (ASP.NET Core)", "Data access for Representatives")
    Component(Representative, "Representative", "Domain Model", "Represents a Shipping Agent Organization Representative")
}


ShippingAgentOrganizationService -[hidden]right-> ShippingAgentOrganization
ShippingAgentOrganizationRepository -[hidden]right-> DbContext


Rel(PAO, ShippingAgentOrganizationController, "Sends HTTP requests", "HTTPS/JSON")
Rel(ShippingAgentOrganizationController, ShippingAgentOrganizationService, "Calls methods in", "Method Calls")
Rel(ShippingAgentOrganizationService, ShippingAgentOrganization, "Uses", "Domain Logic")
Rel(ShippingAgentOrganizationService, RepresentativeService, "Uses", "Method Calls")
Rel(RepresentativeService, RepresentativeRepository, "Uses", "Method Calls")
Rel(ShippingAgentOrganizationService, ShippingAgentOrganizationRepository, "Uses", "Method Calls")
Rel(ShippingAgentOrganizationRepository, DbContext, "Uses", "Method Calls")


Rel(RepresentativeService, Representative, "Uses", "Domain Logic")
Rel(RepresentativeRepository, DbContext, "Uses", "Method Calls")
Rel(DbContext, db, "Reads from and writes to", "EF Core/SQL")

@enduml