@startuml VesselVisitNotificationComponentsLvl3
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Person(SAR, "Shipping Agent Representative", "System user managing vessel visit notifications")

Container_Boundary(VesselVisitNotificationApi, "Vessel Visit Notification API") {
    Component(VesselVisitNotificationController, "Vessel Visit Notification Controller", "ASP.NET Core MVC Controller", "Handles HTTP requests related to Vessel Visit Notifications")
    Component(VesselVisitNotificationService, "Vessel Visit Notification Service", ".NET 8 (ASP.NET Core)", "Business logic for managing Vessel Visit Notifications")
    Component(DecisionRepository, "Decision Repository", ".NET 8 (ASP.NET Core)", "Data access for Decisions")
    Component(DockRepository, "Dock Repository", ".NET 8 (ASP.NET Core)", "Data access for Docks")
    Component(VesselVisitNotificationRepository, "Vessel Visit Notification Repository", ".NET 8 (ASP.NET Core)", "Data access for Vessel Visit Notifications")
    Component(Decision, "Decision", "Domain Model", "Represents a Decision associated with a Vessel Visit Notification")
    Component(DbContext, "DbContext", ".NET 8 (Entity Framework Core)", "EF Core DbContext for Shipping Management")
    ComponentDb(db, "Shipping Management Database", "SQL Server", "Stores all data related to Shipping Management")
}



VesselVisitNotificationRepository -[hidden]right-> DbContext


Rel(SAR, VesselVisitNotificationController, "Sends HTTP requests", "HTTPS/JSON")
Rel(VesselVisitNotificationController, VesselVisitNotificationService, "Calls methods in", "Method Calls")
Rel(VesselVisitNotificationService, Decision, "Uses", "Domain Logic")
Rel(VesselVisitNotificationService, DecisionRepository, "Uses", "Domain Logic")
Rel(VesselVisitNotificationService, VesselVisitNotificationRepository, "Uses", "Method Calls")
Rel(VesselVisitNotificationService, DockRepository, "Uses", "Method Calls")
Rel(VesselVisitNotificationRepository, DbContext, "Uses", "Method Calls")
Rel(DecisionRepository, DbContext, "Uses", "Method Calls")
Rel(DockRepository, DbContext, "Uses", "Method Calls")
Rel(DbContext, db, "Reads from and writes to", "EF Core/SQL")


@enduml